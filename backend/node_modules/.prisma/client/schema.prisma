// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  STATION_MANAGER
  EMPLOYEE
}

enum FuelType {
  DIESEL
  PETROL
  PREMIUM
  KEROSENE
}

enum PumpStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum SalePaymentMethod {
  CASH
  CARD
  FLEET
  MOBILE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  ON_LEAVE
}

enum ShiftType {
  MORNING
  AFTERNOON
  NIGHT
}

enum NotificationType {
  LOW_STOCK
  PUMP_FAULT
  FLEET_CREDIT_LOW
  SALE_CREATED
  REFILL_RECEIVED
  SYSTEM
}

enum NotificationPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ExpenseCategory {
  UTILITIES
  MAINTENANCE
  SALARIES
  SUPPLIES
  TRANSPORT
  MISCELLANEOUS
  MARKETING
  INSURANCE
  TAXES
  OTHER
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PASSWORD_RESET
  EXPORT
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  role         Role      @default(EMPLOYEE)
  avatarUrl    String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  stationId String?
  station   Station? @relation("StationManagers", fields: [stationId], references: [id])

  employee       Employee?
  refreshTokens  RefreshToken[]
  passwordResets PasswordResetToken[]
  sales          Sale[]
  auditLogs      AuditLog[]
  notifications  Notification[]
  attendances    Attendance[]

  @@index([email])
  @@index([stationId])
  @@map("users")
}

model Station {
  id        String   @id @default(uuid())
  name      String
  address   String
  city      String
  state     String
  country   String   @default("US")
  phone     String?
  email     String?
  logoUrl   String?
  isActive  Boolean  @default(true)
  timezone  String   @default("America/New_York")
  currency  String   @default("USD")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  managers      User[]           @relation("StationManagers")
  employees     Employee[]
  tanks         FuelTank[]
  pumps         Pump[]
  sales         Sale[]
  expenses      Expense[]
  fleetAccounts FleetAccount[]
  notifications Notification[]
  settings      StationSettings?
  refills       FuelRefill[]

  @@map("stations")
}

model StationSettings {
  id                       String   @id @default(uuid())
  stationId                String   @unique
  station                  Station  @relation(fields: [stationId], references: [id])
  dieselPrice              Float    @default(0)
  petrolPrice              Float    @default(0)
  premiumPrice             Float    @default(0)
  kerosenePrice            Float    @default(0)
  lowStockThreshold        Float    @default(500)
  criticalStockThreshold   Float    @default(200)
  enableEmailNotifications Boolean  @default(true)
  enableLowStockAlerts     Boolean  @default(true)
  enableFleetAlerts        Boolean  @default(true)
  workingHoursStart        String   @default("06:00")
  workingHoursEnd          String   @default("22:00")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@map("station_settings")
}

model FuelTank {
  id             String   @id @default(uuid())
  name           String
  fuelType       FuelType
  capacityLiters Float
  currentLiters  Float
  minThreshold   Float    @default(500)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  stationId String
  station   Station      @relation(fields: [stationId], references: [id])
  pumps     Pump[]
  sales     Sale[]
  refills   FuelRefill[]

  @@index([stationId])
  @@index([fuelType])
  @@map("fuel_tanks")
}

model Pump {
  id           String     @id @default(uuid())
  pumpNumber   String
  label        String
  status       PumpStatus @default(ACTIVE)
  currentMeter Float      @default(0)
  openingMeter Float      @default(0)
  lastServiced DateTime?
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  stationId     String
  station       Station            @relation(fields: [stationId], references: [id])
  tankId        String
  tank          FuelTank           @relation(fields: [tankId], references: [id])
  sales         Sale[]
  meterReadings PumpMeterReading[]

  @@unique([stationId, pumpNumber])
  @@index([stationId])
  @@map("pumps")
}

model PumpMeterReading {
  id           String   @id @default(uuid())
  pumpId       String
  pump         Pump     @relation(fields: [pumpId], references: [id])
  readingValue Float
  recordedAt   DateTime @default(now())
  recordedBy   String?
  notes        String?

  @@index([pumpId])
  @@map("pump_meter_readings")
}

model Sale {
  id            String            @id @default(uuid())
  invoiceNumber String            @unique
  volumeLiters  Float
  pricePerLiter Float
  totalAmount   Float
  paymentMethod SalePaymentMethod @default(CASH)
  customerName  String?
  customerPhone String?
  vehicleNumber String?
  notes         String?
  isVoided      Boolean           @default(false)
  voidReason    String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  stationId      String
  station        Station       @relation(fields: [stationId], references: [id])
  pumpId         String
  pump           Pump          @relation(fields: [pumpId], references: [id])
  tankId         String
  tank           FuelTank      @relation(fields: [tankId], references: [id])
  employeeId     String
  employee       User          @relation(fields: [employeeId], references: [id])
  fleetAccountId String?
  fleetAccount   FleetAccount? @relation(fields: [fleetAccountId], references: [id])

  @@index([stationId])
  @@index([pumpId])
  @@index([employeeId])
  @@index([createdAt])
  @@index([fleetAccountId])
  @@map("sales")
}

model Supplier {
  id          String   @id @default(uuid())
  name        String
  contactName String?
  phone       String?
  email       String?
  address     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  refills FuelRefill[]

  @@map("suppliers")
}

model FuelRefill {
  id            String   @id @default(uuid())
  volumeLiters  Float
  pricePerLiter Float
  totalCost     Float
  deliveryDate  DateTime
  invoiceNumber String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  stationId  String
  station    Station  @relation(fields: [stationId], references: [id])
  tankId     String
  tank       FuelTank @relation(fields: [tankId], references: [id])
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  @@index([stationId])
  @@index([tankId])
  @@map("fuel_refills")
}

model Employee {
  id               String    @id @default(uuid())
  employeeCode     String    @unique
  position         String
  department       String?
  baseSalary       Float     @default(0)
  hourlyRate       Float?
  hireDate         DateTime
  terminatedAt     DateTime?
  emergencyContact String?
  emergencyPhone   String?
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  userId    String  @unique
  user      User    @relation(fields: [userId], references: [id])
  stationId String
  station   Station @relation(fields: [stationId], references: [id])
  shifts    Shift[]

  @@index([stationId])
  @@map("employees")
}

model Shift {
  id        String    @id @default(uuid())
  shiftType ShiftType
  date      DateTime  @db.Date
  startTime String
  endTime   String
  isPrimary Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@map("shifts")
}

model Attendance {
  id          String           @id @default(uuid())
  date        DateTime         @db.Date
  checkIn     DateTime?
  checkOut    DateTime?
  hoursWorked Float?
  status      AttendanceStatus @default(PRESENT)
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@map("attendances")
}

model FleetAccount {
  id             String   @id @default(uuid())
  accountNumber  String   @unique
  companyName    String
  contactName    String?
  contactPhone   String?
  contactEmail   String?
  creditLimit    Float    @default(50000)
  currentBalance Float    @default(0)
  isActive       Boolean  @default(true)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  stationId String
  station   Station        @relation(fields: [stationId], references: [id])
  sales     Sale[]
  payments  FleetPayment[]

  @@index([stationId])
  @@map("fleet_accounts")
}

model FleetPayment {
  id          String   @id @default(uuid())
  amount      Float
  paymentDate DateTime @default(now())
  reference   String?
  notes       String?
  createdAt   DateTime @default(now())

  fleetAccountId String
  fleetAccount   FleetAccount @relation(fields: [fleetAccountId], references: [id])

  @@index([fleetAccountId])
  @@map("fleet_payments")
}

model Expense {
  id          String          @id @default(uuid())
  title       String
  description String?
  amount      Float
  category    ExpenseCategory
  expenseDate DateTime
  receiptUrl  String?
  isApproved  Boolean         @default(false)
  approvedBy  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  stationId String
  station   Station @relation(fields: [stationId], references: [id])

  @@index([stationId])
  @@index([expenseDate])
  @@map("expenses")
}

model Notification {
  id        String               @id @default(uuid())
  title     String
  message   String
  type      NotificationType
  priority  NotificationPriority @default(MEDIUM)
  isRead    Boolean              @default(false)
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime             @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id])
  stationId String?
  station   Station? @relation(fields: [stationId], references: [id])

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model RefreshToken {
  id            String   @id @default(uuid())
  token         String   @unique
  isBlacklisted Boolean  @default(false)
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([token])
  @@map("password_reset_tokens")
}

model AuditLog {
  id        String      @id @default(uuid())
  action    AuditAction
  entity    String
  entityId  String?
  oldValues Json?
  newValues Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime    @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
