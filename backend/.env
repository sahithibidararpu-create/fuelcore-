# =============================================================
# FuelCore – Environment Configuration
# =============================================================

# ─── App ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000/api/v1
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fuelcore_db?schema=public

# ─── Redis (optional – in-memory fallback if unavailable) ────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ─── JWT (RS256) ──────────────────────────────────────────────
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── Bcrypt ───────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── Email (optional) ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=FuelCore <no-reply@fuelcore.io>

# ─── File Uploads ─────────────────────────────────────────────
UPLOAD_MAX_SIZE_MB=10
UPLOAD_DIR=./uploads

# ─── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000
AUTH_RATE_LIMIT_MAX=20

# ─── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs

# ─── Currency ─────────────────────────────────────────────────
CURRENCY_SYMBOL=₹
CURRENCY_LOCALE=en-IN

# ─── Seed Credentials ─────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@fuelcore.io
SEED_ADMIN_PASSWORD=Admin@1234
